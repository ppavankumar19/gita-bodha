# Bhagavad Gita API (RapidAPI) — for fetching all 700 verses
VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# ElevenLabs Text-to-Speech (Recommended for Telugu voice quality)
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=

# Sarvam AI (Indian language TTS) — plug in when ready
VITE_SARVAM_API_KEY=

# Feature flags
VITE_ENABLE_FAVORITES=true
VITE_ENABLE_DAILY_SLOKA=true
VITE_USE_BROWSER_TTS_FALLBACK=true
